*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

-A FORWARD -i {{ gateway_backend_iface }} -o {{ gateway_uplink_iface }} -j ACCEPT
-A FORWARD -i {{ gateway_uplink_iface }} -o {{ gateway_backend_iface }} -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

-A POSTROUTING -s {{ backend_subnet }} -o {{ gateway_uplink_iface }} -j MASQUERADE

COMMIT